# Copy to deploy/.env.prod and replace every value before starting a shared
# test or production-shaped Compose environment. Do not commit deploy/.env.prod.

ASSOPS_POSTGRES_PASSWORD=change-me-postgres
ASSOPS_GATEWAY_URL=https://assops.example.com
ASSOPS_JWT_SECRET=change-me-jwt-secret-at-least-32-bytes
ASSOPS_WEBHOOK_SECRET_KEY=change-me-webhook-secret-at-least-32-bytes
ASSOPS_ADMIN_EMAIL=admin@example.com
ASSOPS_ADMIN_PASSWORD=change-me-admin-password

# Optional integrations.
ASSOPS_APPROVAL_WEBHOOK_URL=
ASSOPS_APPROVAL_WEBHOOK_TOKEN=
ASSOPS_GITHUB_ACTIONS_READ_TOKEN=
ASSOPS_ARGO_READ_TOKEN=

# Enable this only in a controlled test environment after mounting reviewed,
# namespace-scoped kubeconfig files into the assops_kubeconfigs volume.
ASSOPS_KUBERNETES_LOGS_ENABLED=false
ASSOPS_KUBERNETES_RESTARTS_ENABLED=false
ASSOPS_KUBECTL_PATH=kubectl

# Runtime tuning.
ASSOPS_WORKER_INTERVAL_SECONDS=3
ASSOPS_WORKER_HEALTH_ADDR=:8081
ASSOPS_NODE_WORKER_HEALTH_ADDR=:8082
ASSOPS_WEB_PORT=8080

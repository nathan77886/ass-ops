{
  "name": "assops-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "i18n:check": "node scripts/check-i18n.mjs",
    "function-names:check": "node scripts/check-function-names.mjs",
    "build": "pnpm run i18n:check && pnpm run function-names:check && tsc -b && vite build",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "antd": "^6.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "wrangler": "^4.107.0"
  }
}

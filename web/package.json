{
  "name": "assops-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "i18n:check": "node scripts/check-i18n.mjs",
    "build": "pnpm run i18n:check && tsc -b && vite build",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@vitejs/plugin-react": "^4.6.0",
    "antd": "^5.27.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "wrangler": "^4.105.0"
  }
}
